{
  "name": "canvas-ai",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=21 <24"
  },
  "main": "dist/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "markets": "tsx src/markets-server.ts",
    "start:markets": "node dist/markets-server.js",
    "txline:smoke": "tsx scripts/txline-smoke.ts",
    "agent": "tsx src/agent-server.ts",
    "agent:run": "tsx scripts/agent-run.ts",
    "build": "tsc && tsc-alias",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "node dist/index.js",
    "smoke": "tsx scripts/e2e-smoke.ts",
    "seed:advertiser": "tsx scripts/seed-advertiser.ts",
    "bankr:spike": "tsx scripts/bankr-spike.ts",
    "deploy:escrow": "tsx scripts/deploy-escrow.ts",
    "deposit:campaign": "tsx scripts/deposit-campaign.ts",
    "credit:deposit": "tsx scripts/credit-base-pay-deposit.ts",
    "payout:batch": "tsx scripts/payout-batch.ts",
    "verify:escrow": "tsx scripts/verify-escrow.ts"
  },
  "dependencies": {
    "@base-org/account": "^2.5.6",
    "@coral-xyz/anchor": "^0.32.1",
    "@grammyjs/auto-retry": "^2.0.2",
    "@solana/spl-token": "^0.4.15",
    "@solana/web3.js": "^1.98.4",
    "@types/pg": "^8.18.0",
    "bs58": "^6.0.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "grammy": "^1.43.0",
    "openai": "^6.27.0",
    "pg": "^8.20.0",
    "pino": "^10.1.1",
    "pino-pretty": "^13.1.3",
    "tweetnacl": "^1.0.3",
    "viem": "^2.46.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.11",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.9.5",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.2.4"
  }
}
