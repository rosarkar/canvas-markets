# Copy to `.env` at repo root and/or `src/.env` (root loads first, src/.env overrides).
NODE_ENV=development

DATABASE_URL=postgresql://user:password@localhost:5432/canvas_ai

# Optional: public URL for Telegram Mini App buttons (defaults to TELEGRAM_WEBHOOK_URL origin)
# MINI_APP_BASE_URL=https://canvas-ai-production.up.railway.app

# Seed script (npm run seed:advertiser)
# SEED_ADVERTISER_TG_ID=123456789
# SEED_BID=0.01
# SEED_QUANTITY=1

# Telegram bot (webhook mode)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
PORT=3000

# Telegram user ID that receives operational alert DMs — payout/refund failures,
# stuck-state sweeps. Leave empty to disable alerts.
ADMIN_TELEGRAM_ID=

# Kimi verification scoring
KIMI_API_KEY=

# Base mainnet + payments
BASE_RPC_URL=https://mainnet.base.org
USDC_BASE_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
ESCROW_CONTRACT_ADDRESS=
DEPLOYER_PRIVATE_KEY=
RELAYER_PRIVATE_KEY=

# Company treasury — receives the platform fee on every verified payout
COMPANY_WALLET=
# Platform fee in basis points (100 = 1%, 1000 = 10%). Default: 1000
PLATFORM_FEE_BPS=1000

# Bidding limits (testing defaults)
MIN_BID_MICROUNITS=10000
MIN_CAMPAIGN_QUANTITY=1
DEPOSIT_POLL_INTERVAL_MS=30000
DEPOSIT_TTL_MS=7200000
DEPOSIT_URL_SECRET=
PAYOUT_BATCH_INTERVAL_MS=86400000

# Basescan (npm run verify:escrow)
# BASESCAN_API_KEY=

# Bankr Agent API (optional — npm run bankr:spike; settlement rail for the risk desk)
BANKR_API_KEY=

# OpenAI fallback when Kimi is unavailable
OPENAI_API_KEY=

# --- Canvas Markets (World Cup risk desk — `npm run markets`) ---
# TxODDS live football feed. Empty → the desk runs on sample World Cup fixtures.
TXODDS_API_KEY=
TXODDS_BASE_URL=https://api.txodds.net
# Repeated-bet horizon for the Monte-Carlo bankroll projection.
MARKETS_SIM_HORIZON_BETS=20
# Port for the standalone markets server.
MARKETS_PORT=4000
# Set true (with a BANKR_API_KEY) to place REAL on-chain bets. Default: simulate.
MARKETS_LIVE_SETTLEMENT=false
