# Copy to `.env` at repo root and/or `src/.env` (root loads first, src/.env overrides).
NODE_ENV=development

DATABASE_URL=postgresql://user:password@localhost:5432/canvas_ai

# Telegram bot (webhook mode)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
PORT=3000

# Kimi verification scoring
KIMI_API_KEY=

# Base chain + relayer wallet
BASE_RPC_URL=https://mainnet.base.org
RELAYER_PRIVATE_KEY=

# OpenAI fallback when Kimi is unavailable
OPENAI_API_KEY=
